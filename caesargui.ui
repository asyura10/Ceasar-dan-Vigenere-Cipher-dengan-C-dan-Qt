    <property name="styleSheet">
     <string notr="true">/* =========================================
   1. BACKGROUND UTAMA (Mode Gelap)
   ========================================= */
QWidget#centralwidget, QStackedWidget {
    background-color: #0b0f19; /* Biru sangat gelap ala terminal */
}

/* =========================================
   2. SEMUA TEKS &amp; LABEL
   ========================================= */
QLabel {
    color: #00ffcc; /* Hijau neon/Cyan */
    font-family: &quot;Segoe UI&quot;, &quot;Courier New&quot;;
    font-size: 14px;
    font-weight: bold;
}

/* =========================================
   3. KOTAK INPUT (Pesan, Kunci, Hasil)
   ========================================= */
QLineEdit, QTextEdit, QSpinBox {
    background-color: #131a2a;
    color: #ffffff; /* Teks putih agar terbaca jelas */
    border: 2px solid #1f293d;
    border-radius: 6px;
    padding: 8px;
    font-family: &quot;Consolas&quot;, &quot;Courier New&quot;;
    font-size: 14px;
}

/* Efek saat kotak input diklik (Fokus) */
QLineEdit:focus, QTextEdit:focus, QSpinBox:focus {
    border: 2px solid #00ffcc; /* Menyala hijau/cyan saat diketik */
}

/* =========================================
   4. TOMBOL UTAMA (Enkripsi, Dekripsi, Login)
   ========================================= */
QPushButton {
    background-color: #007acc; /* Biru korporat/profesional */
    color: white;
    border: none;
    border-radius: 6px;
    padding: 10px;
    font-weight: bold;
    font-size: 14px;
}

QPushButton:hover {
    background-color: #0099ff; /* Terang saat di-hover */
}

QPushButton:pressed {
    background-color: #005c99; /* Gelap saat diklik */
}

/* =========================================
   5. TOMBOL KEMBALI &amp; LOGOUT (Warna Merah/Peringatan)
   ========================================= */
/* Kita targetkan langsung nama tombolnya agar warnanya beda sendiri */
QPushButton#btnLogOut, QPushButton#btnBack1, QPushButton#btnBack2 {
    background-color: #cc3333; 
}

QPushButton#btnLogOut:hover, QPushButton#btnBack1:hover, QPushButton#btnBack2:hover {
    background-color: #ff4d4d;
}

QPushButton#btnLogOut:pressed, QPushButton#btnBack1:pressed, QPushButton#btnBack2:pressed {
    background-color: #990000;
}

/* =========================================
   6. TOMBOL SIMPAN (Warna Hijau)
   ========================================= */
QPushButton#btnSimpanVig {
    background-color: #2eb82e;
}

QPushButton#btnSimpanVig:hover {
    background-color: #33cc33;
}</string>
