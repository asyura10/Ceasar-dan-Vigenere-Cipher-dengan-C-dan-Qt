  <property name="styleSheet">
   <string notr="true">/* Background Utama */
QMainWindow, QWidget#centralwidget {
    background-color: #0f172a;
}

/* Tulisan Instruksi */
QLabel {
    color: #38bdf8;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 14px;
    font-weight: bold;
}

/* Kotak Input dan Spinbox */
QLineEdit, QSpinBox {
    background-color: #1e293b;
    color: #ffffff;
    border: 1px solid #334155;
    border-radius: 6px;
    padding: 8px;
}

/* Kotak Hasil (MENGHILANGKAN PUTIH) */
QPlainTextEdit {
    background-color: #020617; /* Lebih gelap dari background utama */
    color: #4ade80; /* Hijau Matrix */
    border: 2px solid #1e293b;
    border-radius: 8px;
    font-family: &quot;Consolas&quot;, monospace;
    font-size: 13px;
}

/* Tombol-Tombol */
QPushButton {
    background-color: #0ea5e9;
    color: white;
    border-radius: 6px;
    padding: 12px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #38bdf8;
}</string>
